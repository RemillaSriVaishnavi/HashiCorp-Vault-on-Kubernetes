############################################
# HashiCorp Vault Configuration
############################################

# Vault API address
VAULT_ADDR=http://vault.vault.svc.cluster.local:8200

# Vault namespace (empty for OSS Vault)
VAULT_NAMESPACE=

# Vault token (USED ONLY FOR LOCAL SETUP / TESTING)
# NEVER commit real tokens
VAULT_TOKEN=replace_with_vault_root_or_test_token


############################################
# Kubernetes Configuration
############################################

# Kubernetes context name (Kind cluster)
KUBE_CONTEXT=kind-vault-demo

# Kubernetes namespace for Vault
VAULT_NAMESPACE_K8S=vault

# Kubernetes namespace for application
APP_NAMESPACE=default


############################################
# Database Configuration (Managed by Vault)
############################################

# Database type
DB_TYPE=postgresql

# Database host (Kubernetes service DNS)
DB_HOST=postgres

# Database port
DB_PORT=5432

# Application database name
DB_NAME=appdb

# NOTE:
# DB username and password are NOT defined here
# They are dynamically generated by Vault


############################################
# Vault Database Secrets Engine
############################################

# Vault database secrets engine path
VAULT_DB_ENGINE_PATH=database

# Vault database role name
VAULT_DB_ROLE=app-role

# Default TTL for dynamic DB credentials
VAULT_DB_DEFAULT_TTL=1h

# Max TTL for dynamic DB credentials
VAULT_DB_MAX_TTL=2h


############################################
# Vault KV Secrets Engine
############################################

# KV engine mount path
VAULT_KV_ENGINE_PATH=secret

# KV secret path for application config
VAULT_KV_APP_CONFIG_PATH=secret/data/app/config


############################################
# Vault Transit Secrets Engine
############################################

# Transit engine mount path
VAULT_TRANSIT_ENGINE_PATH=transit

# Encryption key name
VAULT_TRANSIT_KEY_NAME=my-encryption-key


############################################
# Application Configuration
############################################

# Application name
APP_NAME=sample-app

# Secrets mount directory inside pod
APP_SECRETS_PATH=/vault/secrets

# Enable Vault Agent Injector
VAULT_AGENT_INJECTOR_ENABLED=true


############################################
# Feature Flags
############################################

# Enable audit logging
VAULT_AUDIT_ENABLED=true

# Enable transit encryption
VAULT_TRANSIT_ENABLED=true

# Enable dynamic database credentials
VAULT_DYNAMIC_DB_CREDS_ENABLED=true

VAULT_ROOT_TOKEN=root
